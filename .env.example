# Backend environment variables (used by dotenv in `backend/`)
# If you run the backend from the repo root, this `.env` can live here.
# If you run `npm run dev` inside `backend/`, copy these into `backend/.env`.

PORT=5050
MONGO_URI=mongodb://localhost:27017/migraine
GEMINI_API_KEY=your_gemini_api_key_here

# Upstash Redis (used by Upstash Ratelimit)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Allowed frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173

# Frontend (Vite) environment variables:
# Vite loads env from the folder where you run it (usually `frontend/.env`).
VITE_API_BASE_URL=http://localhost:5050
